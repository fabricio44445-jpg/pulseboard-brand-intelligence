# Copy this value into Streamlit Community Cloud:
# App settings → Secrets
#
# Create a key in Google Cloud Console and enable YouTube Data API v3.
YOUTUBE_API_KEY = "replace-with-your-key"

# Optional but required for durable 30-day accumulation.
SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY = "replace-with-service-role-key"
